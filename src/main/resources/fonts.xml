<?xml version="1.0" encoding="UTF-8"?>
<fontFamilies>
    <!-- Map Times New Roman to DejaVu Serif -->
    <fontFamily name="Times New Roman">
        <normal>DejaVu Serif</normal>
        <bold>DejaVu Serif</bold>
        <italic>DejaVu Serif</italic>
        <boldItalic>DejaVu Serif</boldItalic>
        <pdfEncoding>Identity-H</pdfEncoding>
        <pdfEmbedded>false</pdfEmbedded>
    </fontFamily>

    <!-- Map Arial to DejaVu Sans -->
    <fontFamily name="Arial">
        <normal>DejaVu Sans</normal>
        <bold>DejaVu Sans</bold>
        <italic>DejaVu Sans</italic>
        <boldItalic>DejaVu Sans</boldItalic>
        <pdfEncoding>Identity-H</pdfEncoding>
        <pdfEmbedded>false</pdfEmbedded>
    </fontFamily>

    <!-- Map Courier New to DejaVu Sans Mono -->
    <fontFamily name="Courier New">
        <normal>DejaVu Sans Mono</normal>
        <bold>DejaVu Sans Mono</bold>
        <italic>DejaVu Sans Mono</italic>
        <boldItalic>DejaVu Sans Mono</boldItalic>
        <pdfEncoding>Identity-H</pdfEncoding>
        <pdfEmbedded>false</pdfEmbedded>
    </fontFamily>
</fontFamilies>
