# Docker Environment Configuration
# Copy this file to .env and customize as needed

# Application Version
VERSION=latest

# Port Mapping
HOST_PORT=8080

# Java Memory Settings (adjust based on your needs)
# Xmx: Maximum heap size
# Xms: Initial heap size
JAVA_OPTS=-Xmx1g -Xms512m

# Application Settings
SERVER_PORT=8080
SPRING_APPLICATION_NAME=Reports Server

# Database Configuration
SPRING_DATASOURCE_URL=jdbc:h2:file:/app/data/reportserver;AUTO_SERVER=TRUE
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# Logging Levels
# Options: TRACE, DEBUG, INFO, WARN, ERROR, OFF
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_REPORTSERVER=DEBUG

# File Upload Limits
SPRING_SERVLET_MULTIPART_MAX_FILE_SIZE=50MB
SPRING_SERVLET_MULTIPART_MAX_REQUEST_SIZE=50MB

# H2 Console (useful for debugging, disable in production)
SPRING_H2_CONSOLE_ENABLED=true

# Actuator Endpoints
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=when-authorized

# ReportServer Configuration
NET_SF_JASPERREPORTS_AWT_IGNORE_MISSING_FONT=true
NET_SF_JASPERREPORTS_DEFAULT_FONT_NAME=SansSerif
NET_SF_JASPERREPORTS_DEFAULT_PDF_FONT_NAME=Helvetica

# Production Settings (uncomment for production)
# LOGGING_LEVEL_ROOT=WARN
# LOGGING_LEVEL_COM_REPORTSERVER=INFO
# SPRING_H2_CONSOLE_ENABLED=false
# JAVA_OPTS=-Xmx2g -Xms1g -XX:+UseG1GC
